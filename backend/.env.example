# Copy this file to .env and fill in the values you need.

# --- App ---
APP_NAME=Realtime Voice Assistant
DEBUG=false
HOST=0.0.0.0
PORT=8000

# --- STT ---
STT_PROVIDER_PRIMARY=groq
WHISPER_MODEL_SIZE=small.en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# --- VAD ---dea
VAD_THRESHOLD=0.5
VAD_MIN_SILENCE_MS=700

# --- LLM ---
LLM_PROVIDER_PRIMARY=groq
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
LLM_TIMEOUT_SECONDS=6.0
LLM_MAX_HISTORY_TURNS=10

# --- TTS ---
TTS_PROVIDER_PRIMARY=piper
PIPER_MODEL_PATH=models/piper/en_US-lessac-medium.onnx
PIPER_CONFIG_PATH=models/piper/en_US-lessac-medium.onnx.json

# --- Fallback / UX ---
FILLER_AFTER_SECONDS=1.2
MAX_RESPONSE_WAIT_SECONDS=8.0

# --- Logging ---
LOG_LEVEL=INFO
